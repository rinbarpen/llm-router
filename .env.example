# LLM Router Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Redis (optional)
# ============================================
# Redis 连接 URL（用于存储登录记录等数据，默认 localhost:6379/0）
# LLM_ROUTER_REDIS_URL=redis://localhost:6379/0

# ============================================
# Auth (optional)
# ============================================
# 本机请求是否免认证：true=免认证，false=本机也需 API Key（默认 true）
# LLM_ROUTER_ALLOW_LOCAL_WITHOUT_AUTH=true

# ============================================
# Provider API Keys
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
DASHSCOPE_API_KEY=sk-...  # Qwen
GLM_API_KEY=sk-...        # GLM
KIMI_API_KEY=sk-...       # Moonshot
OPENROUTER_API_KEY=sk-...

# ============================================
# Frontend (optional)
# ============================================
# 仪表盘在“需要认证”环境下访问后端时使用的 API Key（仅前端构建时注入，用于 Authorization）
# VITE_API_KEY=sk-...
# 前端 API 基础 URL（生产环境，默认 /api）
# VITE_API_BASE_URL=/api
