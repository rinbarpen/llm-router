# LLM Router 配置文件
# 配置 Provider、模型和 API Key 设置

######################
# Server Settings    #
######################
# 服务器配置（可选，也可以通过环境变量 LLM_ROUTER_HOST 和 LLM_ROUTER_PORT 设置）
[server]
host = "0.0.0.0"  # 服务绑定的主机地址
port = 18000       # 服务绑定的端口

######################
# Monitor Settings #
######################
# 监控界面配置（可选，也可以通过环境变量 VITE_PORT、VITE_API_URL、VITE_API_BASE_URL 设置）
[monitor]
port = 4022                    # 前端开发服务器端口
api_url = "http://localhost:18000"  # 后端API服务器地址（开发环境代理用）
api_base_url = "/api"          # 生产环境API基础路径

######################
# Model Auto Update  #
######################
[model_updates]
enabled = true
startup_sync = true
interval_hours = 24
write_router_toml = true
default_new_model_active = false
removed_model_policy = "delete_auto_managed"
source_dir = "data/model_sources"
startup_delay_seconds = 5

######################
# Routing Settings  #
######################
[routing]
default_pair = "gemini-3"
load_balance_strategy = "round_robin" # round_robin | weighted | least_failure
# channel_fallback = ["openrouter", "openai", "gemini"]

#[routing.provider_weights]
# openrouter = 3
# openai = 2
# gemini = 1

#[routing.circuit_breaker]
# enabled = true
# failure_threshold = 3
# cooldown_seconds = 30
# half_open_max_requests = 1

[[routing.pairs]]
name = "gemini-3"
strong_model = "gemini/gemini-3.0-pro"
weak_model = "gemini/gemini-3.0-flash"

[[routing.pairs]]
name = "gemini-2.5"
strong_model = "gemini/gemini-2.5-pro"
weak_model = "gemini/gemini-2.5-flash"

######################
# Provider Settings  #
######################

[[providers]]
name = "openai"
type = "openai"
# Environment variable that stores your OpenAI API key
api_key_env = "OPENAI_API_KEY"
base_url = "https://api.openai.com/v1"

# 本地 Codex CLI（使用本机登录态/配额，不走 OPENAI_API_KEY）
# use_app_server=true 时启动常驻进程，支持会话上下文延续；false 时每次调用 codex exec
[[providers]]
name = "codex_cli"
type = "codex_cli"
[providers.settings]
executable = "codex"
skip_git_repo_check = true
timeout = 300
use_app_server = true
# 项目级权限边界（建议保持为仓库根目录）
workspace_root = "/home/rczx/workspace/rinbarpen/llm-router"
# 默认工作目录；未传 workspace_path 时使用
default_workspace_path = "/home/rczx/workspace/rinbarpen/llm-router"
# 是否强制 workspace_path 必须位于 workspace_root 内
enforce_workspace_scope = true
# app-server 调用策略
approval_policy = "never"
sandbox_mode = "workspace-write"
network_access = true

# 本地 OpenCode CLI（Codex 风格 /v1/responses）
[[providers]]
name = "opencode_cli"
type = "opencode_cli"
[providers.settings]
executable = "opencode"
timeout = 300
parser = "codex_jsonl"
args_template = ["exec", "--json", "-m", "{model}", "{prompt}"]
workspace_root = "/home/rczx/workspace/rinbarpen/llm-router"
default_workspace_path = "/home/rczx/workspace/rinbarpen/llm-router"
enforce_workspace_scope = true

# 本地 Kimi Code CLI（Codex 风格 /v1/responses）
[[providers]]
name = "kimi_code_cli"
type = "kimi_code_cli"
[providers.settings]
executable = "kimi"
timeout = 300
parser = "codex_jsonl"
args_template = ["exec", "--json", "-m", "{model}", "{prompt}"]
workspace_root = "/home/rczx/workspace/rinbarpen/llm-router"
default_workspace_path = "/home/rczx/workspace/rinbarpen/llm-router"
enforce_workspace_scope = true

# 本地 Qwen Code CLI（Codex 风格 /v1/responses）
[[providers]]
name = "qwen_code_cli"
type = "qwen_code_cli"
[providers.settings]
executable = "qwen"
timeout = 300
parser = "codex_jsonl"
args_template = ["exec", "--json", "-m", "{model}", "{prompt}"]
workspace_root = "/home/rczx/workspace/rinbarpen/llm-router"
default_workspace_path = "/home/rczx/workspace/rinbarpen/llm-router"
enforce_workspace_scope = true

# 本地 Claude Code CLI（使用本机登录态，无需 API Key）
[[providers]]
name = "claude_code_cli"
type = "claude_code_cli"
[providers.settings]
executable = "claude"
timeout = 300
# claude 的权限模式，默认 bypassPermissions（可改为 acceptEdits / plan）
permission_mode = "bypassPermissions"
workspace_root = "/home/rczx/workspace/rinbarpen/llm-router"
default_workspace_path = "/home/rczx/workspace/rinbarpen/llm-router"
enforce_workspace_scope = true

[[providers]]
name = "azure-openai"
type = "azure_openai"
api_key_env = "AZURE_OPENAI_API_KEY"
base_url = "https://YOUR_RESOURCE_NAME.openai.azure.com"
[providers.settings]
api_version = "2024-02-15-preview"

[[providers]]
name = "huggingface"
type = "huggingface"
api_key_env = "HF_TOKEN"

[[providers]]
name = "doubao (cn)"
type = "doubao"
api_key_env = "DOUBAO_API_KEY"

[[providers]]
name = "doubao (global)"
type = "doubao"
api_key_env = "DOUBAO_API_KEY"
base_url = "https://api.byteplus.com/api/v3"

[[providers]]
name = "minimax (cn)"
type = "minimax"
api_key_env = "MINIMAX_API_KEY"

[[providers]]
name = "minimax (global)"
type = "minimax"
api_key_env = "MINIMAX_API_KEY"
base_url = "https://api.minimaxi.chat/v1"

[[providers]]
name = "gemini"
type = "gemini"
api_key_env = "GEMINI_API_KEY"

[[providers]]
name = "claude"
type = "claude"
api_key_env = "ANTHROPIC_API_KEY"

[[providers]]
name = "openrouter"
type = "openrouter"
api_key_env = "OPENROUTER_API_KEY"

[[providers]]
name = "glm (cn)"
type = "glm"
api_key_env = "GLM_API_KEY"
base_url = "https://open.bigmodel.cn/api/paas/v4"
[providers.settings]
endpoint = "/chat/completions"

[[providers]]
name = "glm (global)"
type = "glm"
api_key_env = "GLM_API_KEY"
base_url = "https://api.z.ai/api/paas/v4"
[providers.settings]
endpoint = "/chat/completions"

[[providers]]
name = "kimi (cn)"
type = "kimi"
api_key_env = "KIMI_API_KEY"

[[providers]]
name = "kimi (global)"
type = "kimi"
api_key_env = "KIMI_API_KEY"
base_url = "https://api.moonshot.cn/v1"

[[providers]]
name = "qwen (cn)"
type = "qwen"
api_key_env = "DASHSCOPE_API_KEY"

[[providers]]
name = "qwen (global)"
type = "qwen"
api_key_env = "DASHSCOPE_API_KEY"
base_url = "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"

[[providers]]
name = "deepseek (cn)"
type = "deepseek"
api_key_env = "DEEPSEEK_API_KEY"
base_url = "https://api.deepseek.com"

[[providers]]
name = "ollama (cn)"
type = "ollama"
# Ollama 不需要 API Key，默认连接到 http://127.0.0.1:11434
# 如果需要连接到其他地址，可以设置 base_url
# base_url = "http://127.0.0.1:11434"

[[providers]]
name = "vercel"
type = "openai"
# Vercel 部署的 OpenAI 兼容服务
# 请将 YOUR_VERCEL_URL 替换为实际的 Vercel 部署地址
base_url = "https://YOUR_VERCEL_URL.vercel.app"
# 如果 Vercel 服务需要 API Key，请设置 api_key_env
# api_key_env = "VERCEL_API_KEY"
# 或者直接设置（不推荐）
# api_key = "your-vercel-api-key"

# Groq (groq.com，非 x.ai)
[[providers]]
name = "groq"
type = "groq"
api_key_env = "GROQ_API_KEY"

# SiliconFlow 硅基流动
[[providers]]
name = "siliconflow"
type = "siliconflow"
api_key_env = "SILICONFLOW_API_KEY"

# AiHubMix API 网关
[[providers]]
name = "aihubmix"
type = "aihubmix"
api_key_env = "AIHUBMIX_API_KEY"

# 第三方 OpenAI 兼容聚合入口（单逻辑 provider，多 base_url 自动降权切换）
[[providers]]
name = "vapi"
type = "openai"
api_key_env = "VAPI_API_KEY"
base_url = "https://api.vveai.com"
[providers.settings]
api_base_urls = [
  "https://api.vveai.com",
  "https://api.gpt.ge",
  "https://api.v3.cm",
]
latency_degrade_threshold_ms = 3000
cooldown_seconds = 30

# VolcEngine 火山引擎（豆包同平台，可接入方舟其他模型）
[[providers]]
name = "volcengine"
type = "volcengine"
api_key_env = "VOLCENGINE_API_KEY"

# vLLM 本地服务
[[providers]]
name = "vllm"
type = "vllm"
base_url = "http://localhost:8000"
[providers.settings]
endpoint = "/v1/chat/completions"
# 无 api_key_env，本地通常免认证


###################
# OpenAI Models   #
###################

[[models]]
name = "gpt-5.3-codex"
provider = "codex_cli"
display_name = "GPT-5.3 Codex (Local CLI)"
remote_identifier = "gpt-5.3-codex"
tags = ["chat", "code", "codex_cli", "local"]
[models.rate_limit]
max_requests = 20
per_seconds = 60
[models.config]
context_window = "272k"
